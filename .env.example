# ─── Database ─────────────────────────────────────────────────────────────────
# Map "casestudy" to 127.0.0.1 in your hosts file (C:\Windows\System32\drivers\etc\hosts)
DB_HOST=casestudy
DB_PORT=3308          # Use any port in range 3306–3310
DB_USER=root
DB_PASS=your_db_password_here
DB_NAME=evelyn_pos

# ─── Pusher (Channels) ────────────────────────────────────────────────────────
# Get these from https://dashboard.pusher.com → Your App → App Keys
# NEVER paste real keys here — this file is committed to GitHub.
PUSHER_APP_ID=your_app_id
PUSHER_APP_KEY=your_app_key
PUSHER_APP_SECRET=your_app_secret
PUSHER_APP_CLUSTER=ap1
